pipeline {

    agent {
        kubernetes {

            yaml '''
apiVersion: v1
kind: Pod

spec:

  serviceAccountName: jenkins

  containers:

  - name: maven
    image: maven:3.9.6-eclipse-temurin-17
    command:
    - cat
    tty: true

  - name: trivy
    image: aquasec/trivy:latest
    command:
    - cat
    tty: true

  - name: sonar
    image: sonarsource/sonar-scanner-cli:latest
    command:
    - cat
    tty: true

  - name: kaniko
    image: gcr.io/kaniko-project/executor:debug
    command:
    - sleep
    args:
    - "9999999"
    tty: true
'''
        }
    }

    environment {

        IMAGE_NAME = "vinod1188/bankapp"
        IMAGE_TAG  = "v${BUILD_NUMBER}"

        SONAR_URL  = "http://sonarqube.sonarqube:9000"
    }

    stages {

        stage('Git Checkout') {

            steps {

                git branch: 'main',
                credentialsId: 'git',
                url: 'https://github.com/vinodk11/ci_mega_project.git'
            }
        }

        stage('Compile') {

            steps {

                container('maven') {

                    sh 'mvn clean compile'
                }
            }
        }

        stage('Unit Testing') {

            steps {

                container('maven') {

                    sh 'mvn test'
                }
            }
        }

        stage('Trivy FileSystem Scan') {

            steps {

                container('trivy') {

                    sh '''
                    trivy fs \
                    --format table \
                    -o fs-report.html .
                    '''
                }
            }
        }

        stage('SonarQube Analysis') {

            steps {

                container('sonar') {

                    withSonarQubeEnv('sonar') {

                        sh '''
                        sonar-scanner \
                        -Dsonar.projectKey=gcbank \
                        -Dsonar.projectName=gcbank \
                        -Dsonar.sources=. \
                        -Dsonar.java.binaries=target \
                        -Dsonar.host.url=$SONAR_URL
                        '''
                    }
                }
            }
        }

        stage('Quality Gate') {

            steps {

                timeout(time: 10, unit: 'MINUTES') {

                    waitForQualityGate abortPipeline: false
                }
            }
        }

        stage('Build Package') {

            steps {

                container('maven') {

                    sh 'mvn package -DskipTests'
                }
            }
        }

        stage('Publish Artifact To Nexus') {

            steps {

                container('maven') {

                    withMaven(
                        globalMavenSettingsConfig: '8c9c8653-545e-4d58-a1f5-60c6da744ca3',
                        traceability: true
                    ) {

                        sh 'mvn deploy -DskipTests'
                    }
                }
            }
        }

        stage('Build & Push Docker Image') {

            steps {

                container('kaniko') {

                    withCredentials([
                        usernamePassword(
                            credentialsId: 'docker-cred',
                            usernameVariable: 'DOCKER_USER',
                            passwordVariable: 'DOCKER_PASS'
                        )
                    ]) {

                        sh '''
                        mkdir -p /kaniko/.docker

                        cat > /kaniko/.docker/config.json <<EOF
                        {
                          "auths": {
                            "https://index.docker.io/v1/": {
                              "username": "$DOCKER_USER",
                              "password": "$DOCKER_PASS"
                            }
                          }
                        }
                        EOF

                        /kaniko/executor \
                          --context $(pwd) \
                          --dockerfile Dockerfile \
                          --destination $IMAGE_NAME:$IMAGE_TAG
                        '''
                    }
                }
            }
        }

        stage('Trivy Docker Image Scan') {

            steps {

                container('trivy') {

                    sh '''
                    trivy image \
                    --format table \
                    -o image-report.html \
                    docker.io/$IMAGE_NAME:$IMAGE_TAG
                    '''
                }
            }
        }
    }

    post {

        always {

            archiveArtifacts artifacts: '*.html', fingerprint: true
        }

        success {

            echo 'Pipeline executed successfully'
        }

        failure {

            echo 'Pipeline failed'
        }
    }
}
